# Copy this file to .env.local and fill in your Supabase project values.
# Find them in Supabase → Project Settings → API.
#
# If you leave these empty, the app still runs fully — it falls back to
# browser localStorage (data stays on this device, synced across tabs).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
